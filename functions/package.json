{
  "name": "functions",
  "description": "Cloud Functions for Firebase",
  "scripts": {
    "emulate": "firebase emulators:start --only auth,firestore,functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "dev": "firebase emulators:start --only hosting,auth,firestore,functions"
  },
  "engines": {
    "node": "16"
  },
  "main": "index.js",
  "dependencies": {
    "firebase-admin": "^11.0.1",
    "firebase-functions": "^4.0.0"
  },
  "devDependencies": {
    "firebase-functions-test": "^0.2.0"
  },
  "private": true
}
